rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // OTP sessions are server-only (Cloud Functions Admin SDK).
      allow read, write: if request.time < timestamp.date(2026, 7, 16)
        && !request.path.matches('.*/phoneOtpSessions/.*');
    }
  }
}
